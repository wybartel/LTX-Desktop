{
  "name": "ltx-desktop",
  "version": "0.0.3",
  "description": "LTX-2 Video Generation - Desktop App",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "Lightricks",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:debug": "DEBUG=1 vite",
    "build": "vite build && electron-builder",
    "build:frontend": "vite build",
    "build:mac": "bash scripts/build-installer.sh --platform mac",
    "build:mac:skip-python": "bash scripts/build-installer.sh --platform mac --skip-python",
    "build:win": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "build:win:skip-python": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1 -SkipPython",
    "build:fast": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1 -Unpack -SkipPython -SkipNpm",
    "prepare:python": "powershell -ExecutionPolicy Bypass -File scripts/prepare-python.ps1",
    "prepare:python:mac": "bash scripts/prepare-python.sh",
    "setup:dev": "powershell -ExecutionPolicy Bypass -File scripts/setup-dev.ps1",
    "setup:dev:mac": "bash scripts/setup-dev.sh",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "npm run build:frontend && electron-builder",
    "typecheck": "tsc --noEmit",
    "start:unpacked": "powershell -Command \"& '.\\release\\win-unpacked\\LTX Desktop.exe'\""
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  }
}
