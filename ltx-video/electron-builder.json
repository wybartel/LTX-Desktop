{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.lightricks.ltx-video",
  "productName": "LTX Video Studio",
  "copyright": "Copyright © 2024 Lightricks",
  "directories": {
    "output": "release",
    "buildResources": "build-resources"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "!**/*.map"
  ],
  "asarUnpack": [
    "dist/splash/**"
  ],
  "extraResources": [
    {
      "from": "backend",
      "to": "backend",
      "filter": [
        "**/*.py",
        "pyproject.toml",
        "!**/__pycache__/**",
        "!**/*.pyc",
        "!.venv/**",
        "!outputs/**",
        "!models/**"
      ]
    },
    {
      "from": "python-embed",
      "to": "python"
    },
    {
      "from": "dist",
      "to": "dist"
    },
    {
      "from": "dist-electron",
      "to": "dist-electron"
    }
  ],
  "win": {
    "target": [
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${version}-win64.${ext}"
  },
  "publish": null
}
