{
  "name": "ltx-video",
  "version": "1.0.0",
  "description": "LTX-2 Video Generation - Desktop App",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "Lightricks",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:frontend": "tsc && vite build",
    "build:installer": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "build:installer:skip-python": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1 -SkipPython",
    "build:fast": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1 -Unpack -SkipPython -SkipNpm",
    "prepare:python": "powershell -ExecutionPolicy Bypass -File scripts/prepare-python.ps1",
    "setup:dev": "powershell -ExecutionPolicy Bypass -File scripts/setup-dev.ps1",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:frontend && electron-builder --config electron-builder.json",
    "typecheck": "tsc --noEmit",
    "start:unpacked": "powershell -Command \"& '.\\release\\win-unpacked\\LTX Desktop.exe'\""
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  }
}
